# Sinopac / market data
SINOPAC_API_KEY=your_sinopac_api_key
SINOPAC_SECRET_KEY=your_sinopac_secret_key
SINOPAC_SIMULATION=false
SINOPAC_CA_PASSWORD=your_ca_password
SINOPAC_PERSON_ID=your_person_id

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/trading

# WebSocket
WS_HOST=127.0.0.1
WS_PORT=8765

# Runtime mode
SINOPAC_MOCK=false
SINOPAC_AUTO_SCAN=true
SINOPAC_SCAN_TOP=100
ENABLE_AUTO_TRADER=true

# OpenAI daily report
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
